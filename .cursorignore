crates/din-wasm/pkg/din_wasm.d.ts
crates/din-wasm/pkg/din_wasm_bg.wasm.d.ts

# Any stray wasm binaries
*.wasm

# If npm tooling is added under pkg or repo root
node_modules/

# Common generated folders
dist/

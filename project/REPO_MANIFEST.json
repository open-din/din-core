{
  "version": 2,
  "repo": {
    "id": "din_core",
    "display_name": "din-core",
    "path": "din-core",
    "role": "din-document-runtime",
    "tags": [
      "rust",
      "din-document",
      "validation",
      "wasm",
      "worker",
      "open-din-v2"
    ],
    "depends_on": [
      "react_din"
    ],
    "used_by": [
      "din_studio",
      "din_agents"
    ],
    "entry_points": [
      "crates/din-document",
      "crates/din-core",
      "crates/din-wasm",
      "fixtures/din-document-v1",
      "project/features"
    ],
    "feature_source": "project/features/*.feature",
    "owned_contracts": [
      "DinDocument native model (serde)",
      "Parse and semantic validation",
      "DocumentHandle and scene route graph views",
      "RuntimeSession and transport/sequencer/bridge controllers",
      "WASM validation, handles, worker JSON dispatch"
    ],
    "shared_contracts": [
      "DinDocument JSON schema (open-din/v2)",
      "serialization and fixture parity",
      "native vs WASM validation diagnostics"
    ],
    "hard_boundaries": [
      "Do not fork DinDocument schema away from open-din/v2 without coordination.",
      "Keep WASM wrappers thin.",
      "Do not move editor logic into Rust crates."
    ],
    "validation_commands": [
      "cargo fmt --all --check",
      "cargo clippy --workspace --all-targets -- -D warnings",
      "cargo test --workspace"
    ],
    "route_card_path": "project/ROUTE_CARD.json",
    "summary_path": "project/SUMMARY.md",
    "userflow_path": "project/USERFLOW.md",
    "test_matrix_path": "project/TEST_MATRIX.md",
    "api_summary_path": "docs/summaries/din-core-api.md",
    "wasm_js_api_path": "crates/din-wasm/pkg/docs/api.md",
    "repo_manifest_path": "project/REPO_MANIFEST.json",
    "skills_path": "project/skills",
    "linked_manifests": []
  }
}
